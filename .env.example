# ==========================================
# Agent Web - Environment Variables
# ==========================================
# Copy this file to .env.local and fill in the values

# ==========================================
# LLM Providers (at least one required)
# ==========================================

# OpenAI (default: OpenRouter)
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Gemini/Google
GEMINI_API_KEY=

# 9Router (local AI gateway — OpenAI-compatible)
NINEROUTER_URL=https://rfb2lzd.9router.com
NINEROUTER_KEY=

# OpenCode
OPENCODE_ZEN_API_KEY=
OPENCODE_GO_API_KEY=

# GitHub Copilot
COPILOT_GITHUB_TOKEN=

# NVIDIA NIM
NVIDIA_API_KEY=

# Alibaba Cloud / DashScope
DASHSCOPE_API_KEY=

# Hugging Face
HF_TOKEN=

# ==========================================
# Encryption
# ==========================================

# Secret key for encrypting API keys at rest.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: If not set, a dev-only fallback is used (insecure for production).
ENCRYPTION_KEY=

# ==========================================
# Database
# ==========================================

# SQLite path (default: local.db in packages/db)
DATABASE_URL=file:./packages/db/data/local.db

# For remote libsql/Turso:
# DATABASE_URL=libsql://your-db-url.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token

# ==========================================
# Terminal Sandbox
# ==========================================

# Backend: local | docker | ssh (default: local)
TERMINAL_BACKEND=local

# Docker sandbox container name (used when TERMINAL_BACKEND=docker)
TERMINAL_SANDBOX_CONTAINER=agent-web-sandbox

# SSH backend credentials
TERMINAL_SSH_HOST=
TERMINAL_SSH_USER=
TERMINAL_SSH_KEY=~/.ssh/id_rsa

# ==========================================
# Memory
# ==========================================

# MEMORY.md character limit (default: 2200)
MEMORY_CHAR_LIMIT=2200

# USER.md character limit (default: 1375)
USER_CHAR_LIMIT=1375

# ==========================================
# Chat
# ==========================================

# Context compression threshold (tokens)
CONTEXT_COMPRESSION_THRESHOLD=80000

# Enable memory injection (default: true)
ENABLE_MEMORY=true

# Auxiliary model for side tasks (summarization, extraction)
AUXILIARY_MODEL=gpt-4o-mini

# ==========================================
# Sandbox (code_execution tool)
# ==========================================

SANDBOX_ENABLED=false
SANDBOX_MAX_CPU_MS=5000
SANDBOX_MAX_MEMORY_MB=256

# ==========================================
# Obsidian Vault Integration
# ==========================================

# Path to your Obsidian vault for chat session sync.
# Sessions will be written to {vault}/Agent Web/{title}.md
# Leave empty to disable auto-sync.
# OBSIDIAN_VAULT_PATH=C:/path/to/obsidian-vault

# ==========================================
# Next.js
# ==========================================

NODE_ENV=development
