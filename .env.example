# ==========================================
# Agent Web - Environment Variables
# ==========================================
# Copy this file to .env.local and fill in the values

# ==========================================
# LLM Provider (DeepSeek)
# ==========================================

# DeepSeek API key is embedded in the codebase.
# No additional LLM environment variables needed.

# ==========================================
# Encryption (REQUIRED)
# ==========================================

# REQUIRED in all environments. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ==========================================
# Database
# ==========================================

# SQLite path (default: ./data/local.db)
DATABASE_URL=file:./data/local.db

# For remote libsql/Turso:
# DATABASE_URL=libsql://your-db-url.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token

# ==========================================
# Terminal Sandbox
# ==========================================

# Backend: local | docker (default: local)
# "docker" runs commands inside an isolated sandbox container
# "local" runs directly with safety blocklist
TERMINAL_BACKEND=local

# Docker sandbox container name (default: agent-web-sandbox)
# TERMINAL_SANDBOX_CONTAINER=agent-web-sandbox

# ==========================================
# Memory
# ==========================================

# Enable persistent memory across sessions (default: false)
ENABLE_MEMORY=true

# Character limit for injected memory content (default: 2200)
MEMORY_CHAR_LIMIT=2200

# ==========================================
# Chat
# ==========================================

# Context compression threshold in tokens (default: 80000)
# Messages beyond this are trimmed (oldest first, sliding window)
CONTEXT_COMPRESSION_THRESHOLD=80000

# ==========================================
# Obsidian Vault Integration
# ==========================================

# Path to your Obsidian vault for chat session sync.
# Sessions will be written to {vault}/Agent Web/{title}.md
# Leave empty to disable auto-sync.
# OBSIDIAN_VAULT_PATH=C:/path/to/obsidian-vault

# ==========================================
# Next.js
# ==========================================

NODE_ENV=development
